# SafeHer server
SAFEHER_HOST=127.0.0.1
SAFEHER_PORT=8000
SAFEHER_SOS_PROVIDER=auto

# Email-only auth is handled locally by the Python backend.
# No OTP, SMS, or SMTP provider configuration is required.

# Fast2SMS automatic SOS delivery.
# Add your Fast2SMS API key to enable direct SMS sending from the backend.
# Default route "q" uses Quick SMS. If you switch to "dlt_manual", also fill
# sender/entity/template details below with your approved DLT values.
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=q
FAST2SMS_LANGUAGE=english
FAST2SMS_TIMEOUT=15
FAST2SMS_SENDER_ID=
FAST2SMS_ENTITY_ID=
FAST2SMS_TEMPLATE_ID=

# Optional: automatic SOS webhook integration.
# Point this to your SMS/WhatsApp relay endpoint so SOS messages are sent
# automatically by the backend without opening WhatsApp in the browser.
# If both webhook and Fast2SMS are configured, Fast2SMS will be used when
# SAFEHER_SOS_PROVIDER=auto and FAST2SMS_API_KEY is present.
SAFEHER_SOS_WEBHOOK_URL=
SAFEHER_SOS_WEBHOOK_BEARER_TOKEN=
SAFEHER_SOS_WEBHOOK_TIMEOUT=15
